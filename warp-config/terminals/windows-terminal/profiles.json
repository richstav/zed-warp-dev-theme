{
  "profiles": {
    "defaults": {
      "colorScheme": "Warp Dark",
      "font": {
        "face": "JetBrains Mono",
        "size": 13
      },
      "cursor": {
        "color": "#00c2ff",
        "shape": "bar",
        "blink": "motion"
      },
      "acrylicOpacity": 0.8,
      "useAcrylic": true,
      "scrollbarState": {
        "scrollback": 10000
      }
    },
    "list": [
